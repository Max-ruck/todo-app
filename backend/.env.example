# ── Pflichtfelder ─────────────────────────────────────────────────────────────
# Langer, zufälliger String – niemals committen!
# Generieren: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=BITTE-AENDERN-VOR-PRODUKTIONSEINSATZ

# ── Datenbank ─────────────────────────────────────────────────────────────────
# Absoluter oder relativer Pfad zur SQLite-Datei
# Relativ = relativ zu backend/main.py
DATABASE_URL=todo.db

# ── Basis-URL ─────────────────────────────────────────────────────────────────
# Wird als Fallback für Einladungslinks verwendet, wenn kein Host-Header gesetzt
BASE_URL=https://DEINE-DOMAIN.de/todo
